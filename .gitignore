# Секреты и окружение
.env
*.env.*

# Данные аккаунтов (прокси, cookies, сессии — НИКОГДА в репо)
accounts/
*.cookies
cookies_*.txt
browser_profile/

# Рабочие данные (analytics, quarantine, memory — меняются в runtime)
data/

# Временные файлы обработки
temp/
*.log
logs/

# TTS модели (530MB — не коммитить)
assets/tts/*.onnx
assets/tts/*.bin

# Python cache (все уровни)
__pycache__/
pipeline/**/__pycache__/
scripts/**/__pycache__/
tests/**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/

# Pytest
.pytest_cache/
*.pytest_ini

# Выходные файлы
output/
outputs/
downloads/
processed/

# Profile browser lock files
accounts/**/.profile.lock
.profile.lock

# ═══════════════════════════════════════════════════════════════════════════════
# ShortsProject — .gitignore
# Python pipeline: YouTube / TikTok / Instagram automated video creation
# Dev: Windows + NVIDIA GPU + Ollama | Prod: локально
# ═══════════════════════════════════════════════════════════════════════════════


# ── СЕКРЕТЫ И ОКРУЖЕНИЕ ────────────────────────────────────────────────────────
.env
.env.*
!.env.example          # шаблон — коммитить можно
*.pem
*.key
secrets.json
secrets.yaml


# ── АККАУНТЫ (КРИТИЧНО — cookies, сессии, прокси, browser profiles) ───────────
accounts/
# Если нужно сохранить структуру папки без данных:
# accounts/.gitkeep → не забудь добавить его вручную
*.cookies
cookies_*.txt
cookies_*.json
cookies.sqlite
cookies.sqlite-*
key4.db
logins.json
browser_profile/
playwright_profile/
*.session
*.session.json
proxies.txt
proxies.json


# ── RUNTIME-ДАННЫЕ (меняются в каждом цикле) ──────────────────────────────────
data/
# Если хочешь зафиксировать структуру:
# !data/.gitkeep
!data/init_db.sql      # SQL-схема — коммитить нужно


